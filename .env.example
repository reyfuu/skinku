APP_NAME="SKINKU B2B Distributor Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# DATABASE (SQL is the single source of truth — no Firestore/Firebase)
# Default: MySQL / MariaDB (XAMPP). To use PostgreSQL switch DB_CONNECTION=pgsql
# and DB_PORT=5432 (enable the pdo_pgsql PHP extension first).
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=skinku_b2b
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# MAIL (forgot/reset password emails). MAIL_MAILER=log writes to storage logs
# during development. Configure SMTP for production.
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@skinku.id"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# INITIAL SUPER ADMIN (consumed by SuperAdminSeeder — never hardcoded in code)
# ---------------------------------------------------------------------------
SUPER_ADMIN_NAME="Super Admin SKINKU"
SUPER_ADMIN_EMAIL="superadmin@skinku.id"
SUPER_ADMIN_USERNAME="superadmin"
SUPER_ADMIN_PASSWORD="ChangeMe123!"

# ---------------------------------------------------------------------------
# OPTIONAL — only if AI features are reintroduced later
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=
# GOOGLE_AI_STUDIO_ENV=  # note: legacy deploy target was Google AI Studio / Cloud Run

VITE_APP_NAME="${APP_NAME}"
